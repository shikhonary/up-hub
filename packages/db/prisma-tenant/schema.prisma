generator client {
    provider = "prisma-client"
    output   = "../tenant-client-types"
}

datasource db {
    provider = "postgresql"
}

// --- Models ---

model CitizenApplication {
    id                  String    @id @default(uuid())
    fullNameEn          String?
    fullNameBn          String
    nid                 String
    birthRegistrationNo String?
    passportNo          String?
    dateOfBirth         DateTime?
    fatherNameEn        String?
    fatherNameBn        String
    motherNameEn        String?
    motherNameBn        String
    occupationEn        String?
    occupationBn        String

    residentStatusEn           String?
    residentStatusBn           String
    educationalQualificationEn String?
    educationalQualificationBn String?
    religionEn                 String?
    religionBn                 String
    genderEn                   String?
    genderBn                   String
    maritalStatusEn            String?
    maritalStatusBn            String

    // Present Address
    presentVillageEn         String?
    presentVillageBn         String
    presentRoadBlockSectorEn String?
    presentRoadBlockSectorBn String?
    presentHoldingNo         String?
    presentWardNo            Int
    presentDistrictEn        String?
    presentDistrictBn        String
    presentUpazilaEn         String?
    presentUpazilaBn         String
    presentPostOfficeEn      String?
    presentPostOfficeBn      String

    // Permanent Address
    permanentVillageEn         String?
    permanentVillageBn         String
    permanentRoadBlockSectorEn String?
    permanentRoadBlockSectorBn String?
    permanentHoldingNo         String?
    permanentWardNo            Int
    permanentDistrictEn        String?
    permanentDistrictBn        String
    permanentUpazilaEn         String?
    permanentUpazilaBn         String
    permanentPostOfficeEn      String?
    permanentPostOfficeBn      String

    // Contact
    mobile     String
    email      String?
    commentsEn String?
    commentsBn String?

    // Lifecycle
    status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
    citizenId String?
    citizen   Citizen? @relation(fields: [citizenId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("citizen_application")
}

model Citizen {
    id                  String   @id @default(uuid())
    fullNameEn          String?
    fullNameBn          String
    nid                 String   @unique // Required and Unique
    birthRegistrationNo String?
    passportNo          String?
    dateOfBirth         DateTime
    fatherNameEn        String?
    fatherNameBn        String
    motherNameEn        String?
    motherNameBn        String
    occupationEn        String?
    occupationBn        String

    residentStatusEn           String?
    residentStatusBn           String
    educationalQualificationEn String?
    educationalQualificationBn String?
    religionEn                 String?
    religionBn                 String
    genderEn                   String?
    genderBn                   String
    maritalStatusEn            String?
    maritalStatusBn            String

    // Present Address
    presentVillageEn         String?
    presentVillageBn         String
    presentRoadBlockSectorEn String?
    presentRoadBlockSectorBn String?
    presentHoldingNo         String?
    presentWardNo            Int
    presentDistrictEn        String?
    presentDistrictBn        String
    presentUpazilaEn         String?
    presentUpazilaBn         String
    presentPostOfficeEn      String?
    presentPostOfficeBn      String

    // Permanent Address
    permanentVillageEn         String?
    permanentVillageBn         String
    permanentRoadBlockSectorEn String?
    permanentRoadBlockSectorBn String?
    permanentHoldingNo         String?
    permanentWardNo            Int
    permanentDistrictEn        String?
    permanentDistrictBn        String
    permanentUpazilaEn         String?
    permanentUpazilaBn         String
    permanentPostOfficeEn      String?
    permanentPostOfficeBn      String

    // Contact
    mobile String
    email  String?

    commentsEn String?
    commentsBn String?

    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    applications            CitizenApplication[]
    familyApplications      FamilyApplication[]
    asFamilyMember          FamilyMember[]
    holdingTaxes            HoldingTax[]
    assessments             AssessmentApplication[]
    certificateApplications CertificateApplication[]

    @@map("citizen")
}

model Ward {
    id          String   @id @default(uuid())
    name        String
    displayName String
    isActive    Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    villages Village[]

    @@map("ward")
}

model Village {
    id          String @id @default(uuid())
    name        String
    displayName String

    wardId String
    ward   Ward   @relation(fields: [wardId], references: [id], onDelete: Cascade)

    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("village")
}

model FamilyApplication {
    id            String   @id @default(uuid())
    applicantName String
    status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    citizenId String
    citizen   Citizen @relation(fields: [citizenId], references: [id])

    members FamilyMember[]

    @@map("family_application")
}

model FamilyMember {
    id String @id @default(uuid())

    // Basic Information
    nameBengali String // নাম (বাংলায়)
    nameEnglish String? // নাম (ইংরেজিতে)

    // Relationship
    relationBengali String // সম্পর্ক (বাংলায়)
    relationEnglish String? // সম্পর্ক (ইংরেজিতে)

    // Identification & Vital Dates
    dateOrAge String // বয়স/ জন্ম তারিখ/ মৃত্যু তারিখ

    // Identification Number (NID, Birth Reg, or Death Reg)
    identityNumber String // জাতীয় পরিচয় পত্র নং/জন্ম নিবন্ধন নং/ মৃত্যু নিবন্ধন নং

    // Status (Stored as String as requested)
    maritalStatus String // বৈবাহিক অবস্থা
    vitalStatus   String // জীবিত/মৃত

    // Relation to the main application
    applicationId String
    application   FamilyApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

    citizenId String?
    citizen   Citizen? @relation(fields: [citizenId], references: [id])

    @@map("family_member")
}

model AssessmentApplication {
    id String @id @default(uuid())

    // --- Relation to Citizen (Optional) ---
    citizenId String?
    citizen   Citizen? @relation(fields: [citizenId], references: [id])

    // --- Personal Information (Required per user request) ---
    fullNameBn      String // নাম (বাংলায়)
    genderBn        String // লিঙ্গ (Choice: পুরুষ/মহিলা/তৃতীয় লিঙ্গ)
    genderEn        String?
    maritalStatusBn String // বৈবাহিক অবস্থা

    // --- Other Personal Information (Optional/Snapshot) ---
    mobile                     String?
    nid                        String?
    birthRegistrationNo        String?
    passportNo                 String?
    dateOfBirth                DateTime?
    fatherNameBn               String?
    motherNameBn               String?
    occupationBn               String?
    residentType               String? // বাসিন্দা (অস্থায়ী/স্থায়ী)
    educationalQualificationBn String?
    religionBn                 String?

    // --- Permanent Address (Required per user request) ---
    holdingNo    String // হোল্ডিং/এসেসমেন্ট নং (Unique identification)
    wardNo       Int // ওয়ার্ড নং (1-9)
    villageBn    String // গ্রাম/মহল্লা/পাড়া
    districtBn   String // জেলা
    upazilaBn    String // উপজেলা/থানা
    postOfficeBn String // পোষ্ট অফিস

    roadBlockSectorBn String? // রোড/ব্লক/সেক্টর

    // --- Survey Data (Required per user request) ---
    maleCount   Int // পুরুষ
    femaleCount Int // মহিলা

    // --- Other Survey Data (Optional) ---
    childCount                 Int?    @default(0)
    disabledCount              Int?    @default(0)
    earningMembers             Int?
    dependentMembers           Int?
    jobSeekersSscPlus          Int?
    entrepreneurSeekersSscPlus Int?
    landOwnership              String?
    annualIncomeSource         String?
    annualIncome               Float?
    hasTubewell                Boolean @default(false)
    majorExpenditureSectors    String?
    remittanceSenders          Int?
    sanitationStatus           String? // স্যানিটেশন অবস্থা (কাঁচা/পাকা)
    hasUtilities               Boolean @default(false)
    isSocialSafetyNetCovered   Boolean @default(false)

    // --- Housing Details (Optional) ---
    multiStoriedBuildingCount Int? @default(0)
    pakaBuildingCount         Int? @default(0)
    semiPakaBuildingCount     Int? @default(0)
    tinShedCount              Int? @default(0)
    kachaHouseCount           Int? @default(0)

    // --- Tax & Assessment (Required per user request) ---
    annualValuation Float // বার্ষিক মূল্যায়ন
    taxRatePercent  Float // ধার্যকৃত কর % (1-7%)
    totalTax        Float // Calculated Total Tax

    remarks   String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    taxes HoldingTax[]

    @@map("assessment_application")
}

model HoldingTax {
    id String @id @default(uuid())

    assessmentId String
    assessment   AssessmentApplication @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

    fiscalYearId String
    fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id])

    citizenId String?
    citizen   Citizen? @relation(fields: [citizenId], references: [id])

    totalAmount Float
    paidAmount  Float  @default(0)
    dueAmount   Float
    status      String @default("UNPAID") // UNPAID, PARTIAL, PAID

    collectedById   String? // User ID from master DB (track who collected)
    collectedByName String?
    paidAt          DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([assessmentId, fiscalYearId])
    @@map("holding_tax")
}

model FiscalYear {
    id        String   @id @default(uuid())
    name      String
    nameBn    String
    startDate DateTime
    endDate   DateTime
    isCurrent Boolean  @default(false)
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    taxes                    HoldingTax[]
    tradeLicenseApplications TradeLicenseApplication[]
    tradeLicenses            TradeLicense[]

    @@map("fiscal_year")
}

model CertificateCounter {
    id     String @id @default(uuid())
    typeEn String @unique // e.g. "CITIZEN_CERTIFICATE"
    typeBn String // e.g. "নাগরিকত্ব সনদ"
    count  Int    @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("certificate_counter")
}

model TradeLicenseCategory {
    id     String @id @default(uuid())
    typeEn String @unique // e.g. "WHOLESALE_BUSINESS"
    typeBn String // e.g. "পাইকারি ব্যবসা"

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    applications TradeLicenseApplication[]

    @@map("trade_license_category")
}

model TradeLicenseApplication {
    id         String @id @default(uuid())
    trackingId String @unique // User-friendly numeric ID: e.g., 24051310452382

    // --- Organization Info ---
    orgNameEn       String?
    orgNameBn       String
    ownershipTypeBn String // Enum: Private, Partnership, Joint Venture, etc.
    ownershipTypeEn String?

    // --- Owner Info ---
    fullNameEn          String?
    fullNameBn          String
    tinBn               String?
    tinEn               String?
    binBn               String?
    binEn               String?
    fatherNameEn        String?
    fatherNameBn        String
    motherNameEn        String?
    motherNameBn        String
    nidBn               String?
    nidEn               String?
    birthRegistrationBn String?
    birthRegistrationEn String?
    passportBn          String?
    passportEn          String?

    // --- Present Address ---
    presentVillageEn    String?
    presentVillageBn    String
    presentRoadBlockEn  String?
    presentRoadBlockBn  String?
    presentDivisionEn   String?
    presentDivisionBn   String?
    presentHoldingNoBn  String?
    presentHoldingNoEn  String?
    presentWardNo       Int
    presentDistrictEn   String?
    presentDistrictBn   String
    presentUpazilaEn    String?
    presentUpazilaBn    String
    presentPostOfficeEn String?
    presentPostOfficeBn String

    // --- Permanent Address ---
    permanentIsSameAsPresent Boolean @default(false)
    permanentVillageEn       String?
    permanentVillageBn       String
    permanentRoadBlockEn     String?
    permanentRoadBlockBn     String?
    permanentDivisionEn      String?
    permanentDivisionBn      String?
    permanentHoldingNoBn     String?
    permanentHoldingNoEn     String?
    permanentWardNo          Int
    permanentDistrictEn      String?
    permanentDistrictBn      String
    permanentUpazilaEn       String?
    permanentUpazilaBn       String
    permanentPostOfficeEn    String?
    permanentPostOfficeBn    String

    // --- Business Details ---
    vatIdBn           String?
    vatIdEn           String?
    taxIdBn           String?
    taxIdEn           String?
    paidUpCapital     Float?
    businessStartDate DateTime?
    ownershipStatusBn String?
    ownershipStatusEn String?
    signboardSize     Float?

    // Relations
    tradeLicenseCategoryId String
    tradeLicenseCategory   TradeLicenseCategory @relation(fields: [tradeLicenseCategoryId], references: [id])

    fiscalYearId String
    fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id])

    // --- Business Address ---
    businessVillageEn    String?
    businessVillageBn    String
    businessRoadBlockEn  String?
    businessRoadBlockBn  String?
    businessDivisionEn   String?
    businessDivisionBn   String
    businessHoldingNoBn  String?
    businessHoldingNoEn  String?
    businessWardNo       Int
    businessDistrictEn   String?
    businessDistrictBn   String
    businessUpazilaEn    String?
    businessUpazilaBn    String
    businessPostOfficeEn String?
    businessPostOfficeBn String

    // --- Contact Info ---
    mobileBn        String
    mobileEn        String?
    email           String?
    applicantNameEn String?
    applicantNameBn String
    phoneBn         String?
    phoneEn         String?

    // --- Lifecycle ---
    status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    tradeLicense TradeLicense?

    @@map("trade_license_application")
}

model TradeLicense {
    id String @id @default(uuid())

    // --- Identification ---
    licenseNo  String? @unique
    trackingNo String  @unique

    // --- Relations ---
    applicationId String                  @unique
    application   TradeLicenseApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

    fiscalYearId String
    fiscalYear   FiscalYear @relation(fields: [fiscalYearId], references: [id])

    // --- Financial Details ---
    licenseFee        Float   @default(0)
    arrears           Float   @default(0)
    arrearsFiscalYear String?
    discount          Float   @default(0)
    vatAmount         Float   @default(0) // 15% VAT
    signboardTax      Float   @default(0)
    professionalTax   Float   @default(0)
    subCharge         Float   @default(0)
    totalAmount       Float

    // --- Payment Information ---
    paymentStatus String    @default("UNPAID") // UNPAID, PAID
    paymentType   String? // Cash, Cheque, Bank, etc.
    paymentDate   DateTime?

    // --- Validity ---
    issueDate  DateTime @default(now())
    expiryDate DateTime // End of fiscal year

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("trade_license")
}

model CertificateApplication {
    id String @id @default(uuid())

    // --- Certificate Type ---
    certificateTypeEn String // e.g. "CHARACTER_CERTIFICATE"
    certificateTypeBn String // e.g. "চারিত্রিক সনদ"

    // --- Link to Citizen (Core Details source of truth) ---
    citizenId String
    citizen   Citizen @relation(fields: [citizenId], references: [id])

    // --- Specific Data (Typed via JSON) ---
    // Instead of duplicating fields, specific data like income amount or character known duration goes here.
    // The application logic should enforce that inside this JSON, every string field has an En and Bn key 
    // (e.g., { "incomeSourceEn": "Business", "incomeSourceBn": "ব্যবসা" })
    specificData Json?

    // --- Lifecycle ---
    status   String    @default("PENDING") // PENDING, APPROVED, REJECTED
    issuedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("certificate_application")
}

model SuccessionApplication {
    id         String @id @default(uuid())
    trackingId String @unique // User-friendly numeric ID

    // --- Deceased Info ---
    nameEn         String?
    nameBn         String
    nidNo          String?
    deathDate      DateTime?
    fatherNameEn   String?
    fatherNameBn   String
    motherNameEn   String?
    motherNameBn   String
    residentStatus String // Enum: Temporary, Permanent
    religion       String // Enum: Islam, Hindu, Buddhism, Christianity, Others
    gender         String // Enum: Male, Female, Third Gender
    maritalStatus  String // Enum: Unmarried, Married, Divorced, Widow, Others

    // --- Applicant Info ---
    applicantNameEn         String?
    applicantNameBn         String
    applicantGuardianNameEn String?
    applicantGuardianNameBn String
    attachmentFile          Bytes?
    deceasedPreWarish       String? // Pre-deceased Heir info

    // --- Present Address ---
    presentVillageEn         String?
    presentVillageBn         String
    presentRoadBlockSectorEn String?
    presentRoadBlockSectorBn String?
    presentHoldingNo         String?
    presentWardNo            Int
    presentDistrictEn        String?
    presentDistrictBn        String
    presentUpazilaEn         String?
    presentUpazilaBn         String
    presentPostOfficeEn      String?
    presentPostOfficeBn      String

    // --- Permanent Address ---
    permanentVillageEn         String?
    permanentVillageBn         String
    permanentRoadBlockSectorEn String?
    permanentRoadBlockSectorBn String?
    permanentHoldingNo         String?
    permanentWardNo            Int
    permanentDistrictEn        String?
    permanentDistrictBn        String
    permanentUpazilaEn         String?
    permanentUpazilaBn         String
    permanentPostOfficeEn      String?
    permanentPostOfficeBn      String

    // --- Lifecycle ---
    status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    heirs Heir[]

    @@map("succession_application")
}

model Heir {
    id String @id @default(uuid())

    serialNo      Int?
    heirNameBn    String
    heirNameEn    String?
    relationBn    String
    relationEn    String?
    ageDobDod     String?
    idNo          String?
    maritalStatus String?
    isAlive       String?

    applicationId String
    application   SuccessionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

    @@map("heir")
}
